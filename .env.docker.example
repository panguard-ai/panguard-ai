# .env.docker.example
# Copy this file to .env.docker and fill in all values before running docker compose.
# Never commit .env.docker to source control.

# MinIO object storage credentials (used by the minio service and minio-setup job)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Litestream S3-compatible backup credentials (point at the MinIO service for local dev)
LITESTREAM_S3_ACCESS_KEY_ID=
LITESTREAM_S3_SECRET_ACCESS_KEY=

# Threat Cloud admin API key (protects write-protected endpoints)
TC_ADMIN_API_KEY=

# Threat Cloud contributor-hash secret (REQUIRED to serve /api/contributors).
# Anonymises client ids via HMAC; without it the server refuses to hash. Generate: openssl rand -hex 32
TC_HASH_SECRET=

# Threat Cloud client API keys (comma-separated, optional if TC_API_KEY_REQUIRED=false)
TC_API_KEYS=

# Anthropic API key for LLM-assisted ATR proposal review
ANTHROPIC_API_KEY=
