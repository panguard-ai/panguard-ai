# Supabase (from project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Service role — server-only (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=ey...

# Threat Cloud API (events + endpoints source of truth)
TC_API_URL=https://tc.panguard.ai
TC_INTERNAL_SECRET=shared-secret-between-app-and-tc

# HMAC signing key for report downloads (32+ bytes of entropy)
PANGUARD_REPORT_SIGNING_KEY=replace-with-openssl-rand-hex-32

# Public site URL (used to build magic-link redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3001
