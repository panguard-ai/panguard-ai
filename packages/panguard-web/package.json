{
  "name": "@panguard-ai/panguard-web",
  "version": "1.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/panguard-ai/panguard-ai"
  },
  "homepage": "https://panguard.ai",
  "type": "module",
  "description": "Panguard AI official website engine - scenario-based copy + online guidance / Panguard AI 官網引擎 - 場景化文案 + 線上引導",
