    "dev": "tsc --build --watch",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@panguard-ai/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.7.3"
  }
}
