{
  "name": "@panguard-ai/atr",
  "version": "1.8.6",
  "type": "module",
  "description": "Thin wrapper around agent-threat-rules — re-exports all detection logic for monorepo consumers.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./quality": {
      "types": "./dist/quality.d.ts",
      "import": "./dist/quality.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/panguard-ai/panguard-ai.git",
    "directory": "packages/atr"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "echo 'Tests run in agent-threat-rules upstream'",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "agent-threat-rules": "^3.5.8"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.7.3"
  }
}
