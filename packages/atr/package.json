    "test": "echo 'Tests run in agent-threat-rules upstream'",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "agent-threat-rules": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.7.3"
  }
}
