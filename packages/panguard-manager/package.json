{
  "name": "@panguard-ai/panguard-manager",
  "version": "0.1.0",
  "type": "module",
  "description": "PanGuard Manager — self-hosted fleet aggregator for multi-endpoint Pilot/Enterprise deployments.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "panguard-manager": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').copyFileSync('src/dashboard.html','dist/dashboard.html')\"",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts serve --port 8090"
  },
  "dependencies": {
    "@panguard-ai/core": "workspace:*",
    "@panguard-ai/panguard-guard": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "~5.7.3",
    "vitest": "^3.0.0"
  }
}
