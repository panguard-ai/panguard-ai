# Panguard AI Website - Environment Variables
# Copy to .env.local for local development

# ── Backend API (server-side only — never expose to browser bundle) ──────────
# URL of the Panguard auth/billing API server used by /api/waitlist server route.
# Must NOT be NEXT_PUBLIC_* to avoid leaking to the client bundle.
WAITLIST_API_URL=http://localhost:3000

# ── Threat Cloud (server-side only) ──────────────────────────────────────────
# Used by /api/scan and /api/scan/badge server routes.
# Must NOT be NEXT_PUBLIC_* to avoid leaking to the client bundle.
# The client-side useEcosystemStats hook uses NEXT_PUBLIC_THREAT_CLOUD_URL separately.
THREAT_CLOUD_URL=http://localhost:3003

# ── Checkout (set to 'true' when Lemon Squeezy is approved) ─────
# When false, paid plan CTAs link to early-access waitlist
NEXT_PUBLIC_CHECKOUT_ENABLED=false

# ── Analytics (optional) ─────────────────────────────────────────
# Set to enable Plausible privacy-friendly analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=panguard.ai

# ── Manager & Threat Cloud (optional) ────────────────────────────
# NEXT_PUBLIC_MANAGER_URL=http://localhost:3002
# NEXT_PUBLIC_THREAT_CLOUD_URL=http://localhost:3003

# ── Search Engine Verification (optional) ────────────────────────
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ── Lead Capture ──────────────────────────────────────────────────
# Optional: webhook URL to forward form submissions (Zapier, Make, etc.)
# If not set, leads are saved to local JSON files (data/*.json)
LEAD_WEBHOOK_URL=

# ── Google Sheets (optional - sync leads to Google Sheets) ───────
# GOOGLE_SHEETS_ID=your-spreadsheet-id
# GOOGLE_SERVICE_ACCOUNT_EMAIL=panguard@project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
