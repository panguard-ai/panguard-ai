{
  "name": "@panguard-ai/panguard",
  "version": "1.3.5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/panguard-ai/panguard-ai"
  },
  "homepage": "https://panguard.ai",
  "type": "module",
  "description": "Panguard AI - Unified security CLI",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "panguard": "./bin/panguard.cjs",
    "pga": "./bin/panguard.cjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "CHANGELOG.md",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build && cp ../../CHANGELOG.md ./CHANGELOG.md 2>/dev/null || true",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --build --watch",
    "prepublishOnly": "pnpm run build",
    "postinstall": "node -e \"console.log('\\n  Panguard AI v' + require('./package.json').version + ' installed.\\n\\n  Quick start:\\n    pga              Open interactive menu\\n    pga up           Start protection + dashboard\\n    pga scan         Scan your skills\\n    pga audit <dir>  Audit a skill before installing\\n\\n  First time? Just run: pga\\n')\""
  },
  "dependencies": {
    "@panguard-ai/atr": "workspace:*",
    "@panguard-ai/core": "workspace:*",
    "@panguard-ai/panguard-scan": "workspace:*",
    "@panguard-ai/panguard-guard": "workspace:*",
    "@panguard-ai/panguard-report": "workspace:*",
    "@panguard-ai/panguard-chat": "workspace:*",
    "@panguard-ai/security-hardening": "workspace:*",
    "@panguard-ai/scan-core": "workspace:*",
    "@panguard-ai/panguard-skill-auditor": "workspace:*",
    "@panguard-ai/panguard-mcp": "workspace:*",
    "commander": "^12.0.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@panguard-ai/panguard-auth": "workspace:*",
    "@panguard-ai/manager": "workspace:*",
    "@panguard-ai/threat-cloud": "workspace:*",
    "@panguard-ai/panguard-trap": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "typescript": "~5.7.3"
  }
}
