{
  "name": "@panguard-ai/threat-cloud",
  "version": "1.4.2",
  "type": "module",
  "description": "Threat Cloud backend API for collective threat intelligence / 威脅雲後端 API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/panguard-ai/panguard-ai"
  },
  "homepage": "https://panguard.ai",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "threat-cloud": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && (tsc --build --force 2>/dev/null || tsc -p tsconfig.railway.json)",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsc --build --watch",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@panguard-ai/atr": "workspace:*",
    "@panguard-ai/core": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "typescript": "~5.7.3"
  }
}
