{
  "name": "panguard-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-driven adaptive cybersecurity platform / AI 驅動的自適應資安防護平台",
  "author": "Panguard AI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/panguard-ai/panguard-ai"
  },
  "homepage": "https://panguard.ai",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --stream build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml}\"",
    "typecheck": "pnpm -r --stream typecheck",
    "clean": "pnpm -r --stream clean",
    "dev": "pnpm -r --parallel --stream dev",
    "ci:lint": "pnpm run lint && pnpm run format:check",
    "ci:test": "pnpm run typecheck && pnpm run test",
    "ci:build": "pnpm run build",
    "release": "./scripts/release.sh",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "preflight": "pnpm build && pnpm test && pnpm run format:check",
    "panguard": "node packages/panguard/dist/cli/index.js",
    "cli": "node packages/panguard/dist/cli/index.js",
    "website:dev": "pnpm --filter @panguard-ai/website dev",
    "website:build": "pnpm --filter @panguard-ai/website build",
    "test:installer": "vitest run tests/installer",
    "website:start": "pnpm --filter @panguard-ai/website start"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-security": "^3.0.1",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "@swc/core",
      "sharp",
      "@parcel/watcher",
      "unrs-resolver"
    ],
    "overrides": {
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "express-rate-limit": ">=8.2.2"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
