{
  "name": "panguard-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-driven adaptive cybersecurity platform / AI 驅動的自適應資安防護平台",
  "author": "Panguard AI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/panguard-ai/panguard-ai"
  },
  "homepage": "https://panguard.ai",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --stream build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml}\"",
    "typecheck": "pnpm -r --stream typecheck",
    "clean": "pnpm -r --stream clean",
    "dev": "pnpm -r --parallel --stream dev",
    "ci:lint": "pnpm run lint && pnpm run format:check",
    "ci:test": "pnpm run typecheck && pnpm run test",
    "ci:build": "pnpm run build",
    "release": "./scripts/release.sh",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "preflight": "pnpm build && pnpm test && pnpm run format:check",
    "panguard": "node packages/panguard/dist/cli/index.js",
    "cli": "node packages/panguard/dist/cli/index.js",
    "website:dev": "pnpm --filter @panguard-ai/website dev",
    "website:build": "pnpm --filter @panguard-ai/website build",
    "test:installer": "vitest run tests/installer",
    "website:start": "pnpm --filter @panguard-ai/website start"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-security": "^3.0.1",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3",
      "@swc/core",
      "sharp",
      "@parcel/watcher",
      "unrs-resolver"
    ],
    "overrides": {
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "express-rate-limit": ">=8.2.2",
      "flatted@<3.4.0": ">=3.4.0",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0",
      "next@>=9.5.0 <15.5.13": ">=15.5.13",
      "next@>=10.0.0 <15.5.14": ">=15.5.14",
      "flatted@<=3.4.1": ">=3.4.2",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "hono@<4.12.12": ">=4.12.12",
      "hono@>=4.0.0 <=4.12.11": ">=4.12.12",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "next@>=13.0.0 <15.5.15": ">=15.5.15",
      "next-intl@<4.9.1": ">=4.9.1",
      "hono@<4.12.14": ">=4.12.14",
      "fontkit": ">=2.0.4",
      "pdfkit": ">=0.18.0"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
