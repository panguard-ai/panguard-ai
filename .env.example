# Panguard AI - Environment Variables
# Copy this file to .env and fill in your values

# ── Server ─────────────────────────────────────────────────────────
PANGUARD_PORT=3000
PANGUARD_HOST=127.0.0.1
PANGUARD_BASE_URL=http://localhost:3000

# ── Auth Database ──────────────────────────────────────────────────
# Path to SQLite database file (default: ~/.panguard/auth.db)
PANGUARD_AUTH_DB=./panguard-auth.db

# ── CORS ───────────────────────────────────────────────────────────
# Comma-separated origins (or * for all). Default: same-origin only
# CORS_ALLOWED_ORIGINS=https://panguard.ai,http://localhost:3001

# ── Email (Resend recommended, SMTP fallback) ──────────────────────
# Option A: Resend (recommended) — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Panguard AI <noreply@panguard.ai>

# Option B: Raw SMTP (used if RESEND_API_KEY not set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@panguard.ai

# ── Google OAuth (optional - "Sign in with Google") ────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Google Sheets (optional - auto-sync waitlist) ──────────────────
# Create a service account and share the sheet with it
GOOGLE_SHEETS_ID=your-spreadsheet-id
GOOGLE_SHEETS_SA_EMAIL=panguard@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Error Tracking (optional) ─────────────────────────────────────
# Install @sentry/node to enable. Falls back to console.error if unset.
# SENTRY_DSN=https://xxxx@sentry.io/1234

# Sentry — error tracking. Leave unset to disable.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
PANGUARD_SENTRY_DSN=
SENTRY_AUTH_TOKEN=  # for source map upload at build time
GIT_SHA=  # set in CI, used as Sentry release tag

# ── AI Providers ──────────────────────────────────────────────────
# At least one AI provider key is required for Guard threat analysis
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# PANGUARD_LLM_MODEL=claude-sonnet-4-20250514

# ── IP Reputation (optional) ──────────────────────────────────────
# ABUSEIPDB_KEY=your-api-key

# ── Syslog Integration (optional) ─────────────────────────────────
# PANGUARD_SYSLOG_SERVER=syslog.example.com
# PANGUARD_SYSLOG_PORT=514

# ── Credential Encryption (optional) ──────────────────────────────
# 32-byte hex key for encrypting stored credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# PANGUARD_CREDENTIAL_KEY=

# ── TOTP 2FA Encryption (required if 2FA is enabled) ─────────────
# AES-256-GCM key for encrypting TOTP secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# TOTP_ENCRYPTION_KEY=

# ── Falco / Suricata (optional - auto-detected paths) ─────────────
# FALCO_ALERTS_PATH=/var/log/falco/alerts.json
# SURICATA_EVE_PATH=/var/log/suricata/eve.json

# ── Manager API ─────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -hex 32
# MANAGER_AUTH_TOKEN=

# ── Threat Cloud (standalone server) ──────────────────────────────
# TC_API_KEYS=key1,key2
# TC_BACKUP_DIR=/var/backups/threat-cloud

# ── Website Analytics (optional) ──────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=panguard.ai

# ── Website ───────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.panguard.ai
# NEXT_PUBLIC_CHECKOUT_ENABLED=false
# LEAD_WEBHOOK_URL=

# ── Stripe Billing (app.panguard.ai) ──────────────────────────────
# Set via Stripe Dashboard — do not commit real values.
# Server-side secret key. Use sk_test_* in sandbox, sk_live_* in prod.
STRIPE_SECRET_KEY=sk_test_xxx
# Set via Stripe Dashboard — do not commit real values.
# Endpoint signing secret for /api/billing/webhook. From Dashboard → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Set via Stripe Dashboard — do not commit real values.
# Price ID for the Pilot tier subscription product.
STRIPE_PRICE_ID_PILOT=price_xxx
# Set via Stripe Dashboard — do not commit real values.
# Price ID for the Enterprise tier subscription product.
STRIPE_PRICE_ID_ENTERPRISE=price_xxx

# ── License Signing (ed25519 / EdDSA) ─────────────────────────────
# Server-side private key used by app.panguard.ai to mint license JWTs.
# Base64-encoded PKCS8 PEM. Generate with: openssl genpkey -algorithm ed25519 -out priv.pem && base64 < priv.pem
LICENSE_SIGNING_KEY_PRIVATE_PEM=<base64-pkcs8>
# Client-side public key shipped with panguard-guard so it can verify JWTs locally.
# Base64-encoded SPKI PEM. Generate with: openssl pkey -in priv.pem -pubout -out pub.pem && base64 < pub.pem
NEXT_PUBLIC_LICENSE_PUBLIC_KEY_PEM=<base64-spki>

# ── Litestream — TC SQLite continuous replication ─────────────────
# Set ALL of these in production. For local dev, defaults point at the
# bundled MinIO service started by docker-compose (no creds required).
# In production point these at Cloudflare R2, AWS S3, or Backblaze B2.
# If any of these are unset in prod, Litestream fails fast on container
# start (intentional — silent backup failure on customer data is worse).
LITESTREAM_S3_ENDPOINT=http://minio:9000
LITESTREAM_S3_BUCKET=tc-backup
LITESTREAM_S3_REGION=us-east-1
LITESTREAM_S3_ACCESS_KEY_ID=minioadmin
LITESTREAM_S3_SECRET_ACCESS_KEY=minioadmin
